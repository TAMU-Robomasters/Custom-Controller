static inline uint16_t crc16_update(uint16_t crc, uint8_t ch)
{
  return (uint16_t)((crc >> 8) ^ CRC16_TAB[(crc ^ ch) & 0xFF]);
}

static uint8_t crc8_calc(const uint8_t* msg, size_t len) {
  uint8_t crc = CRC8_INIT;
  while (len--) crc = CRC8_TAB[crc ^ *msg++];
  return crc;
}

static uint16_t crc16_calc(const uint8_t* msg, size_t len) {
  uint16_t crc = CRC16_INIT;
  while (len--) {
    uint8_t ch = *msg++;
    crc = (crc >> 8) ^ CRC16_TAB[(crc ^ ch) & 0xFF];
  }
  return crc;
}

static twai_timing_config_t timingFor(uint32_t bitrate) {
  switch (bitrate) {
    case 250000:  return TWAI_TIMING_CONFIG_250KBITS();
    case 500000:  return TWAI_TIMING_CONFIG_500KBITS();
    case 1000000: return TWAI_TIMING_CONFIG_1MBITS();
    default:      return TWAI_TIMING_CONFIG_1MBITS();
  }
}

static uint8_t latestPayload[PAYLOAD_LEN] = {0};
static volatile bool havePayload = false;
static uint8_t payloadSeq = 0;

// VTM UART frame parser
//  header: 0xA5, data_len(2), seq(1), crc8(1)
//  cmd_id(2) + payload[data_len] + crc16(2)

enum class RxState : uint8_t {
  WAIT_SOF,
  READ_HEADER_REST,   
  READ_BODY          
};

static RxState rxState = RxState::WAIT_SOF;
static uint8_t header[5] = {0};
static uint16_t dataLen = 0;
static uint8_t body[2 + 256 + 2]; // cmd(2) + payload(max 256) + crc16(2)
static uint16_t bodyNeed = 0;
static uint16_t bodyHave = 0;

static void resetParser() {
  rxState = RxState::WAIT_SOF;
  dataLen = 0;
  bodyNeed = 0;
  bodyHave = 0;
}

static void handleCompleteFrame(const uint8_t hdr[5], const uint8_t* b, uint16_t bLen) {
  // bLen = 2 + dataLen + 2
  if (bLen < 4) return;

  const uint16_t cmd = (uint16_t)b[0] | ((uint16_t)b[1] << 8);
  const uint8_t* payload = &b[2];
  const uint16_t payloadLen = (uint16_t)(bLen - 4);

  uint16_t calc = crc16_calc(hdr, 5);
  calc = crc16_calc(b, 2 + payloadLen);
}

static bool verifyCrc16_stream(const uint8_t hdr[5], const uint8_t* body, uint16_t bodyLen, uint16_t dataLen)
{
  if (bodyLen != (uint16_t)(2 + dataLen + 2)) return false;
  if (dataLen > 256) return false;

  const uint16_t got = (uint16_t)body[2 + dataLen] | ((uint16_t)body[2 + dataLen + 1] << 8);

  uint16_t crc = CRC16_INIT;

  // header
  for (int i = 0; i < 5; i++) crc = crc16_update(crc, hdr[i]);

  // cmd_id + payload
  const uint16_t n = (uint16_t)(2 + dataLen);
  for (uint16_t i = 0; i < n; i++) crc = crc16_update(crc, body[i]);

  return crc == got;
}

static void processUartByte(uint8_t ch) {
  switch (rxState) {
    case RxState::WAIT_SOF:
      if (ch == 0xA5) {
        header[0] = ch;
        rxState = RxState::READ_HEADER_REST;
        bodyHave = 0;
      }
      break;

    case RxState::READ_HEADER_REST:
      header[1 + bodyHave] = ch;
      bodyHave++;
      if (bodyHave == 4) {
        bodyHave = 0;
        dataLen = (uint16_t)header[1] | ((uint16_t)header[2] << 8);

        uint8_t crc8 = crc8_calc(header, 4);
        if (crc8 != header[4]) {
          resetParser();
          break;
        }

        if (dataLen > 256) { resetParser(); break; }
        bodyNeed = (uint16_t)(2 + dataLen + 2);
        rxState = RxState::READ_BODY;
      }
      break;

    case RxState::READ_BODY:
      if (bodyHave < sizeof(body)) body[bodyHave++] = ch;
      else { resetParser(); break; }

      if (bodyHave == bodyNeed) {
        if (verifyCrc16_stream(header, body, bodyNeed, dataLen)) {
          uint16_t cmd = (uint16_t)body[0] | ((uint16_t)body[1] << 8);
          if (cmd == 0x0302 && dataLen == 30) {
            memcpy(latestPayload, &body[2], 30);
            havePayload = true;
            payloadSeq++;
          }
        }
        resetParser();
      }
      break;
  }
}

// CAN message send ----------------------
static uint32_t lastReplyMs = 0;

static bool sendSegFrame(uint8_t seqVal, uint8_t seg, const uint8_t sixBytes[6]) {
  twai_message_t msg = {};
  msg.identifier = CAN_ID_RESP;
  msg.extd = 0;
  msg.rtr  = 0;
  msg.data_length_code = 8;
  msg.data[0] = seqVal;
  msg.data[1] = seg;
  memcpy(&msg.data[2], sixBytes, 6);
  return twai_transmit(&msg, pdMS_TO_TICKS(10)) == ESP_OK;
}

static void replyWithLatestPayload() {
  const uint32_t now = millis();
  if (now - lastReplyMs < MIN_REPLY_INTERVAL_MS) return;
  lastReplyMs = now;

  uint8_t local[PAYLOAD_LEN];
  if (havePayload) memcpy(local, latestPayload, PAYLOAD_LEN);
  else memset(local, 0, PAYLOAD_LEN);

  const uint8_t seqVal = payloadSeq;

  for (uint8_t seg = 0; seg < NUM_SEGS; seg++) {
    uint8_t chunk[6];
    memcpy(chunk, &local[seg * BYTES_PER_SEG], BYTES_PER_SEG);
    (void)sendSegFrame(seqVal, seg, chunk);
  }
}

void setup() {
  Serial.begin(115200);
  delay(200);

  // CAN init
  twai_general_config_t g_config =
      TWAI_GENERAL_CONFIG_DEFAULT((gpio_num_t)CAN_TX_PIN, (gpio_num_t)CAN_RX_PIN, TWAI_MODE_NORMAL);
  twai_timing_config_t t_config = timingFor(CAN_BITRATE);
  twai_filter_config_t f_config = TWAI_FILTER_CONFIG_ACCEPT_ALL();

  if (twai_driver_install(&g_config, &t_config, &f_config) != ESP_OK) {
    Serial.println("TWAI install failed");
    while (true) delay(1000);
  }
  if (twai_start() != ESP_OK) {
    Serial.println("TWAI start failed");
    while (true) delay(1000);
  }

  // UART init
  Serial1.begin(VTM_BAUD, SERIAL_8N1, VTM_UART_RX_PIN, VTM_UART_TX_PIN);

  Serial.printf("Bridge ready. VTM UART baud=%lu, CAN=%lu\n", (unsigned long)VTM_BAUD, (unsigned long)CAN_BITRATE);
  resetParser();
}

void loop() {
  while (Serial1.available()) {
    processUartByte((uint8_t)Serial1.read());
  }

  twai_message_t rx = {};
  esp_err_t err = twai_receive(&rx, pdMS_TO_TICKS(10));
  if (err == ESP_OK) {
    if (rx.identifier == CAN_ID_POLL_RTR && rx.rtr) {
      replyWithLatestPayload();
    }
  }

  // debug serial print
  static uint32_t lastPrint = 0;
  uint32_t now = millis();
  if (now - lastPrint > 1000) {
    lastPrint = now;
    Serial.printf("havePayload=%d payloadSeq=%u\n", havePayload ? 1 : 0, payloadSeq);
  }
}
