// CCadapter UART to CAN bridge
// this is only needed because dev board is hardware limited to 2 UART busses

// For esp32-s3 supermini + TJA1050 + 24v-5v step down converter

static const int CAN_TX_PIN = 4;
static const int CAN_RX_PIN = 5;

static const int VTM_UART_RX_PIN = 44;
static const int VTM_UART_TX_PIN = -1;   // TODO: implement sending data to VTM (for drawing dynamic data on the client)

// VTM baud is 115200, not 921600 like what the manual said
static const uint32_t VTM_BAUD = 115200;

static const uint32_t CAN_BITRATE = 1000000;

static const uint32_t CAN_ID_POLL_RTR = 0x350; 
static const uint32_t CAN_ID_RESP     = 0x351; 

// can reassembly format
static const int PAYLOAD_LEN = 30;
static const int NUM_SEGS = 5;
static const int BYTES_PER_SEG = 6;

// respond rate limit (prevents ice mode)
static const uint32_t MIN_REPLY_INTERVAL_MS = 10;

